[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/Rajommkar/Riyasat.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
[branch "feature/sidebar-and-refine"]
	remote = origin
	merge = refs/heads/feature/sidebar-and-refine
	vscode-merge-base = origin/main
[branch "properties"]
	remote = origin
	merge = refs/heads/properties
	vscode-merge-base = origin/main
[branch "add-property"]
	remote = origin
	merge = refs/heads/add-property
	vscode-merge-base = origin/properties
[branch "displaying-properties"]
	remote = origin
	merge = refs/heads/displaying-properties
